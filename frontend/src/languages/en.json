      "queueProcessTorrentCheckIntervalSeconds": "Polling interval for single-torrent jobs. Lower values reduce queue latency but add DB polling load.",
      "queueProcessTorrentTimeoutSeconds": "Timeout per single-torrent job. Too low may cause retries; too high can hold worker slots longer.",
      "queueProcessTorrentBatchConcurrency": "Parallel workers for batch reprocessing jobs. Higher values speed bulk tasks but compete for DB resources.",
      "queueProcessTorrentBatchCheckIntervalSeconds": "Polling interval for batch jobs. Lower values make scheduling more responsive with more DB checks.",
      "queueProcessTorrentBatchTimeoutSeconds": "Timeout per batch job. Increase when large batches are expected to avoid premature retries.",
      "queueRefreshMediaMetadataConcurrency": "Parallel metadata refresh workers. Higher values improve backfill speed but increase API and DB load.",
