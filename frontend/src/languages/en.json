      "dhtSavePieces": "Whether to persist torrent piece hashes. Enabling significantly increases storage and write volume.",
      "dhtRescrapeThresholdHours": "Minimum interval before re-scraping swarms. Lower values improve freshness but increase outbound scraping workload.",
      "dhtStatusLogIntervalSeconds": "Crawler status log cadence. Lower values increase observability and log volume.",
      "dhtGetOldestNodesIntervalSeconds": "Frequency of old-node scans in the routing table. Lower values make node rotation more aggressive.",
      "dhtOldPeerThresholdMinutes": "Age threshold for selecting old peers. Lower values rotate peers earlier and can increase lookup churn.",
