      "queueRefreshMediaMetadataTimeoutSeconds": "Timeout per metadata refresh task. Increase if metadata sources are slow.",
      "queueBackfillCoverCacheConcurrency": "Parallel cover-cache workers. Higher values speed image backfill but increase network and disk activity.",
      "queueBackfillCoverCacheCheckIntervalSeconds": "Polling interval for cover-cache queue. Lower values pick up jobs faster at the cost of more polling.",
      "queueBackfillCoverCacheTimeoutSeconds": "Timeout per cover-cache task. Increase when image sources are slower or unstable.",
      "mediaAutoCacheCover": "Controls whether cover images are pre-warmed automatically after content updates. Disable to reduce network/disk load.",
      "mediaAutoFetchBilingual": "Controls whether bilingual media metadata is enriched automatically after content updates. Disable to reduce external API/DB load."
